# Chrome remote debugging
CHROME_DEBUG_PORT=9222
XIANYU_IM_URL=https://www.goofish.com/im

# Product description injected into prompt
XIANYU_ITEM_DESC=（在此填写你的商品/服务名称）

# Reply behavior
XIANYU_REFRESH_AFTER_REPLY=1
XIANYU_REPLY_GAP_SEC=0.8

# Optional: debug log for poller
XIANYU_POLL_DEBUG=0
XIANYU_POLL_DEBUG_LOG=./xianyu_poller.debug.log

# Human-like typing
XIANYU_FAST_INPUT=0
XIANYU_TYPING_INTERVAL_SEC=0.035
XIANYU_TYPING_INTERVAL_JITTER_SEC=0.020

# OpenClaw (optional)
NODE_BIN=node
OPENCLAW_BIN=openclaw
OPENCLAW_AGENT_ID=
OPENCLAW_TIMEOUT_SEC=120

